# =============================================================================
# Cheirin de Pão — variáveis de ambiente (raiz)
# Referência rápida. O backend completo fica em apps/api/.env.example
# e o frontend em apps/web/.env.example.
#
# As 3 variáveis [OBRIGATÓRIA] são validadas no boot da API (@fastify/env):
# sem qualquer uma delas, a API NÃO SOBE.
# =============================================================================

# -------------------- OBRIGATÓRIAS (a API não sobe sem elas) ------------------

# [OBRIGATÓRIA] MongoDB Atlas — connection string (Atlas dashboard > Connect)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cheirin-dev?retryWrites=true&w=majority"

# [OBRIGATÓRIA] JWT — segredo de assinatura do access token. Gere um valor forte, ex.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-use-a-long-random-secret"

# [OBRIGATÓRIA] Stripe Secret Key (sk_test_... em dev, sk_live_... em prod). Server-side apenas.
# Obter em https://dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...

# --------------------------- OPCIONAIS (têm default) --------------------------

# API server
API_PORT=3001
API_HOST=0.0.0.0

# OneSignal (frontend)
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id-here
