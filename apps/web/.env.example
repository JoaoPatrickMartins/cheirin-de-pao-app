# ===== Phase 3 — Mercado Pago (frontend) =====

# Mesma MP_PUBLIC_KEY do backend, prefixada com VITE_ para Vite
# NUNCA adicionar MP_ACCESS_TOKEN ou MP_WEBHOOK_SECRET aqui — apenas a chave pública é segura para o bundle
VITE_MP_PUBLIC_KEY=TEST-...

# ===== Stripe (frontend) =====
# Publishable Key do Stripe (pk_test_.../pk_live_...) — segura para o bundle.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
