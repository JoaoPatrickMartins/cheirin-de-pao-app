# MongoDB Atlas (required — get from Atlas dashboard)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cheirin-dev?retryWrites=true&w=majority"

# API server
API_PORT=3001
API_HOST=0.0.0.0

# ===== Phase 2 — Authentication =====

# Zenvia SMS (required in production — used to send OTP via SMS)
# Get your token at: https://app.zenvia.com/home/credentials
ZENVIA_TOKEN=

# Zenvia sender ID (the short name/number that appears as SMS sender)
ZENVIA_FROM=

# Resend (required in production — used to send OTP via e-mail)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=

# Resend sender address (e.g. "Cheirin de Pão <noreply@cheirin.com.br>")
RESEND_FROM=

# Dev bypass — when NODE_ENV=development, any OTP_DEV_CODE is accepted without sending real messages
# Set to a fixed code during local development (default: 1234)
OTP_DEV_CODE=1234

# First Admin user — seeded automatically on first boot if the Admin collection is empty
# Optional: leave blank to skip automatic seeding
ADMIN_NAME=
ADMIN_PHONE=
ADMIN_EMAIL=
ADMIN_CPF=

# # ===== Phase 3 — Mercado Pago =====

# # MP Access Token (sandbox em dev, produção em prod)
# # Obter em https://www.mercadopago.com.br/developers > Credenciais de teste
# MP_ACCESS_TOKEN=TEST-...

# # Segredo do webhook configurado no painel MP
# MP_WEBHOOK_SECRET=...

# # Chave pública de teste — usada no frontend via VITE_MP_PUBLIC_KEY
# MP_PUBLIC_KEY=TEST-...

# ===== Phase 3.1 — Stripe (migração de pagamentos: cartão sem CVV + Pix) =====

# Secret Key (sk_test_... em dev, sk_live_... em prod). Server-side apenas.
# Obter em https://dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...

# Publishable Key (pk_test_.../pk_live_...). Usada no frontend via VITE_STRIPE_PUBLISHABLE_KEY.
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret (whsec_...). Obter ao criar o endpoint de webhook no painel Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== Phase 4 — OneSignal Push Notifications =====

# OneSignal App ID — obter em https://app.onesignal.com > Settings > Keys & IDs
ONESIGNAL_APP_ID=your-app-id

# OneSignal REST API Key — obter em https://app.onesignal.com > Settings > Keys & IDs
ONESIGNAL_REST_API_KEY=your-rest-api-key
