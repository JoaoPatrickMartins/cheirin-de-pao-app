# =============================================================================
# Cheirin de Pão — API (backend)
# Copie para apps/api/.env e preencha os valores.
#
# As variáveis marcadas com [OBRIGATÓRIA] são validadas no boot (@fastify/env).
# Se qualquer uma faltar, a API NÃO SOBE.
# =============================================================================

# -------------------- OBRIGATÓRIAS (a API não sobe sem elas) ------------------

# [OBRIGATÓRIA] MongoDB Atlas — connection string (Atlas dashboard > Connect)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cheirin-dev?retryWrites=true&w=majority"

# [OBRIGATÓRIA] JWT — segredo de assinatura do access token. Use um valor forte e único.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-use-a-long-random-secret"

# [OBRIGATÓRIA] Stripe Secret Key (sk_test_... em dev, sk_live_... em prod). Server-side apenas.
# Obter em https://dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...

# --------------------------- OPCIONAIS (têm default) --------------------------

# API server
API_PORT=3001
API_HOST=0.0.0.0

# NODE_ENV=production desativa o bypass de OTP e ativa os crons (default: development)
NODE_ENV=development

# Dev bypass — quando NODE_ENV=development, este código é aceito sem enviar e-mail real
OTP_DEV_CODE=1234

# CORS — em produção aponte para o domínio do app (default: http://localhost:5173)
# CORS_ORIGIN=https://app.cheirindepao.com.br

# ----------------------------- INTEGRAÇÕES ------------------------------------

# OTP de acesso é enviado apenas por e-mail neste primeiro momento.
# (O segundo canal — WhatsApp — será adicionado futuramente.)

# Resend (OBRIGATÓRIO EM PRODUÇÃO — envia o OTP por e-mail)
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Remetente verificado, ex.: "Cheirin de Pão <noreply@cheirin.com.br>"
RESEND_FROM=

# Stripe — Publishable Key (pk_test_.../pk_live_...). Usada no frontend via VITE_STRIPE_PUBLISHABLE_KEY.
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe — Webhook signing secret (whsec_...). Obter ao criar o endpoint de webhook no painel Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago — Pix (OBRIGATÓRIO para gerar cobranças Pix). Access Token de produção: painel MP > Suas integrações.
MP_ACCESS_TOKEN=APP_USR-...
# Assinatura secreta do webhook do MP (painel > Webhooks). Só necessária p/ o endpoint público.
MP_WEBHOOK_SECRET=

# OneSignal (push) — obter em https://app.onesignal.com > Settings > Keys & IDs
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_REST_API_KEY=your-rest-api-key

# ----------------------------- ADMIN INICIAL ----------------------------------
# Admin semeado automaticamente no 1º boot se não existir nenhum usuário ADMIN.
# O seed só roda com ADMIN_NAME + (ADMIN_EMAIL ou ADMIN_PHONE) + ADMIN_CPF preenchidos.
ADMIN_NAME=
ADMIN_PHONE=
ADMIN_EMAIL=
ADMIN_CPF=
