// Prisma v6.19.3 — MongoDB adapter
// NEVER run `prisma migrate dev` — MongoDB does not support Prisma migrations
// Only use: `prisma generate` (after schema changes) and `prisma validate` (CI)

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ===== COMPOSITE TYPES (embedded documents) =====

type Address {
  street     String
  number     String
  complement String?
  city       String
  state      String
  zip        String
}

type DeliverySlot {
  slotId      String? // identificador estável interno (ex.: "manha" | "tarde") — chave de referência futura
  name        String  // legado/identidade atual; mantido igual ao slotId
  label       String? // rótulo de exibição (ex.: "Manhã") — editável
  emoji       String? // emoji de exibição (ex.: "☀️") — editável
  time        String  // "06:30" — chave de junção (agendas/pedidos); read-only na Etapa A
  cutoffTime  String  // "22:00" — editável
  isActive    Boolean
}

// ===== ENUMS =====

enum UserRole {
  CLIENT
  COURIER
  ADMIN
}

enum CondoType {
  SINGLE_ENTRANCE
  BLOCKS
}

enum DiscountType {
  PERCENT
  FIXED
}

enum TransactionType {
  PURCHASE
  DELIVERY
  REFUND
  EXPIRY
  ADMIN_GRANT
  ADMIN_DEBIT
}

enum OrderType {
  SINGLE
  SCHEDULED
}

enum OrderStatus {
  SCHEDULED
  SEPARATED
  OUT_FOR_DELIVERY
  DELIVERED
  NOT_DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  CONFIRMED
}

enum DeliveryListStatus {
  OPEN
  CLOSED
  COMPLETED
}

enum PurchaseOrderStatus {
  DRAFT
  FINALIZED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Finalidade de um Payment. Ausente/null = CREDITS (compra de créditos combo/avulso) —
// nullable de propósito: docs criados antes deste campo leem null no Mongo (o @default só
// vale na criação). HOOK = compra de um gancho de porta adicional (não credita pães).
enum PaymentPurpose {
  CREDITS
  HOOK
}

// Tipo do gancho de porta concedido ao cliente (ver model HookRequest).
enum HookRequestType {
  FREE  // 1º gancho gratuito — ao comprar um combo OU pedido único >= mínimo configurado
  PAID  // gancho adicional pago (Pix) — reposição por defeito/perda
  BONUS // gancho concedido pelo admin como bonificação (sem custo)
}

// Estado do ciclo de vida de um gancho.
enum HookRequestStatus {
  PENDING_PAYMENT // PAID aguardando confirmação do pagamento (ainda não entra na fila)
  REQUESTED       // na fila — aguardando a entrega física pelo admin
  DELIVERED       // entregue ao cliente (auditável)
  CANCELLED       // pagamento falhou/expirou (PAID que nunca confirmou)
}

enum NotificationType {
  DELIVERY_EVE
  DELIVERY_DONE
  LOW_CREDIT
  CUTOFF
  RECONFIGURE
  CREDIT_PURCHASED
  CREDIT_GRANTED
  SCHEDULE_PAUSED
  HOOK_DELIVERED
  // Admin — avisos operacionais (cada um com toggle individual em adminNotificationPrefs)
  ADMIN_ORDER_PLACED
  ADMIN_HOOK_REQUESTED
  ADMIN_DELIVERY_DONE
  ADMIN_DELIVERY_FAILED
  ADMIN_DELIVERY_PENDING
  ADMIN_ORDER_CANCELLED
  ADMIN_CREDIT_PURCHASED
  ADMIN_CUTOFF_REACHED
  ADMIN_AUTOGEN_WARNING
  ADMIN_AUTOGEN_DONE
  // Entregador — avisos automáticos (sem toggle)
  COURIER_NEW_ORDERS
  COURIER_PENDING_REMINDER
}

enum AnalyticsEventType {
  ACCESS // abertura do app / carga da PWA por um visitante (anônimo)
  LOGIN  // verificação de OTP bem-sucedida que cria uma sessão
}

// ===== MODELS (15 collections) =====

// 1. User — clientes, entregadores e admins
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String?   @unique
  phone         String?   @unique
  role          UserRole
  name          String
  cpf           String    @unique
  birthDate     DateTime?
  // Auth por senha (bcrypt). null = ainda não definiu — força definição no 1º acesso via OTP.
  // Nunca expor este campo em respostas/selects públicos.
  passwordHash  String?
  passwordSetAt DateTime?
  isBlocked     Boolean   @default(false)
  // Contexto do bloqueio atual (auditoria) — preenchido ao bloquear, limpo ao desbloquear
  blockReason   String?
  blockedAt     DateTime?
  blockedById   String?   @db.ObjectId
  condominiumId String?   @db.ObjectId
  apartment     String?
  block         String?
  creditBalance      Int       @default(0)
  autoRecharge       Json?
  // Preferências de notificação do ADMIN — mapa { [NotificationType]: boolean }.
  // Ausência/null = todos os tipos ligados; só grava as chaves DESLIGADAS (false).
  adminNotificationPrefs Json?
  cardTokenMp        String?
  oneSignalPlayerId  String?
  mpCustomerId       String?
  stripeCustomerId   String?
  // Consentimento explícito para cobranças sem CVV (off_session / card-on-file)
  offSessionConsentAt DateTime?
  // LEGADO — gancho de porta. Migrado para a coleção HookRequest (um doc por gancho).
  // Mantidos apenas para o backfill (scripts/backfill-hook-requests.ts) ler o estado antigo.
  // NÃO escrever mais aqui: a fonte da verdade agora é HookRequest. Podem ser removidos
  // após o backfill rodar em produção.
  hookRequestedAt    DateTime?
  hookDeliveredAt    DateTime?
  hookDeliveredById  String?   @db.ObjectId
  // Tutorial de primeiro acesso — momento em que o cliente concluiu/pulou o onboarding.
  // FONTE DE VERDADE de "já viu o tutorial": null/ausente = ainda não concluiu (mostra
  // automaticamente no 1º acesso). Lido em GET /client/onboarding, gravado uma única
  // vez em POST /client/onboarding/complete.
  onboardingCompletedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// 2. Condominium — condomínios cadastrados
model Condominium {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       Address
  // Coordenadas usadas pela rota do entregador (OSRM). Definidas manualmente pelo admin
  // ou geocodificadas (Nominatim) ao criar/editar. Nulas enquanto não localizado.
  lat           Float?
  lng           Float?
  // true quando a geocodificação só resolveu a nível de cidade (centro) — impreciso.
  approxLocation Boolean @default(false)
  type          CondoType
  // Número de blocos/torres — usado apenas quando type == BLOCKS. Nulo em SINGLE_ENTRANCE.
  numBlocks     Int?
  isActive      Boolean   @default(true)
  deliverySlots DeliverySlot[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 3. Combo — pacotes de créditos de pãezinhos
model Combo {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  quantity       Int
  price          Float
  tag            String?
  // Subtítulo curto exibido no card (ex.: "O equilíbrio da casa")
  description    String?
  // Liga/desliga a tag de economia no card. A economia é calculada automaticamente
  // comparando o preço do combo com comprar a mesma quantidade no avulso (avulsoUnit).
  // Nullable de propósito: combos criados antes deste campo leem null no Mongo (o
  // @default só vale na criação) — o código trata null/ausente como "ligada".
  showEconomy    Boolean? @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// 4. Promotion — promoções e descontos temporários por combo
model Promotion {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  comboId       String       @db.ObjectId
  discountType  DiscountType
  discountValue Float
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// 5. Setting — configurações globais (horário de corte, preço avulso, etc.)
model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. CreditTransaction — movimentação de créditos (imutável — sem updatedAt)
model CreditTransaction {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  userId      String          @db.ObjectId
  type        TransactionType
  quantity    Int
  referenceId String?
  description String?
  adminId     String?         @db.ObjectId
  reason      String?
  createdAt   DateTime        @default(now())
}

// 7. Schedule — agendamento semanal personalizado por cliente
model Schedule {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  condominiumId     String   @db.ObjectId
  weeklyQty         Json?
  deliveryTime      String?
  notifyReconfigure Boolean  @default(false)
  isActive          Boolean  @default(true)
  // Pausa da agenda pelo próprio cliente. null = não pausada; preenchido = pausada desde então.
  // Gate no corte é feito em código (if schedule.pausedAt) — evita null-vs-unset do Mongo.
  pausedAt          DateTime?
  // Último lembrete "pausada há muito tempo" enviado — controla a cadência semanal.
  lastPauseReminderAt DateTime?
  days              Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, condominiumId])
}

// 8. Order — pedidos unitários (avulsos ou gerados pelo schedule)
model Order {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @db.ObjectId
  type           OrderType
  quantity       Int
  scheduledDate  DateTime
  status         OrderStatus
  deliveryListId String?     @db.ObjectId
  courierId      String?     @db.ObjectId
  condominiumId  String?     @db.ObjectId
  slotId         String?     // identificador estável do slot (chave de junção; Etapa B)
  deliveryTime   String?     // snapshot do horário de entrega no momento do pedido (exibição)
  paymentId      String?     @db.ObjectId // vínculo leve ao Payment que financiou o avulso (só quando houve pagamento; nulo quando pago via saldo). Base do estorno de dinheiro a partir de um pedido parado.
  // Marcos do ciclo de vida (rastreabilidade ponta-a-ponta — evita pedido "no limbo")
  separatedAt    DateTime?   // quando foi separado/conferido (entra na divisão de entregas)
  deliveredAt    DateTime?   // quando foi confirmado como entregue
  failedAt       DateTime?   // quando foi marcado como NÃO entregue
  failureReason  String?     // motivo da não-entrega (cliente ausente, endereço, etc.)
  cancelledAt    DateTime?   // quando foi cancelado
  cancelReason   String?     // motivo do cancelamento
  deliveryNote   String?     // nota da entrega manual/retroativa (resolução de pedido parado marcado como entregue)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, scheduledDate])
  @@index([condominiumId, scheduledDate])
}

// 9. Delivery — registro de entrega com confirmação por entregador
model Delivery {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  orderId     String         @db.ObjectId
  courierId   String         @db.ObjectId
  deliveredAt DateTime?
  confirmedAt DateTime?
  status      DeliveryStatus
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// 10. DeliveryList — lista consolidada por condomínio para entregadores
model DeliveryList {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime
  condominiumId String             @db.ObjectId
  courierId     String?            @db.ObjectId
  status        DeliveryListStatus
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

// 11. Supplier — fornecedores de pãezinhos
model Supplier {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  cnpj         String   @unique
  phone        String?
  email        String?
  address      Address
  pricePerUnit Float
  isActive     Boolean  @default(true)
  isPrincipal  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 12. PurchaseOrder — pedidos de compra ao fornecedor (cabeçalho)
// Um pedido por TURNO (slot): cada (date, slotId) gera seu próprio PurchaseOrder.
model PurchaseOrder {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime
  slotId        String?             // turno do pedido (manha/tarde) — pipeline por slot
  slotLabel     String?             // rótulo de exibição do turno (ex.: "Manhã")
  totalQuantity Int
  cutoffTime    DateTime
  status        PurchaseOrderStatus
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

// 13. PurchaseOrderItem — itens do pedido separados por fornecedor
model PurchaseOrderItem {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId String   @db.ObjectId
  supplierId      String   @db.ObjectId
  quantity        Int
  unitPrice       Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 14. Payment — pagamentos via Mercado Pago (Pix/cartão)
model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @db.ObjectId
  amount        Float
  method        PaymentMethod
  status        PaymentStatus
  // Legados/Stripe: SEM @unique — índice único do Mongo rejeita múltiplos nulls
  // (todo pagamento Stripe tem mercadoPagoId null; pagamentos MP antigos têm
  // stripePaymentIntentId ausente). Idempotência é garantida na aplicação.
  mercadoPagoId  String?
  stripePaymentIntentId String?
  comboId        String?       @db.ObjectId
  customQuantity Int?
  // Finalidade do pagamento. Ausente/null = CREDITS (compra de créditos). HOOK = gancho
  // adicional pago — o fulfillment (credit-payment.ts) NÃO credita pães; marca o HookRequest.
  purpose        PaymentPurpose?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// 20. HookRequest — cada gancho de porta que um cliente obtém ao longo do tempo.
// Substitui os campos hook* do User (single-slot) por histórico: 1 grátis + N pagos/bônus.
// Regra do grátis "uma vez só": cliente elegível ⇔ NÃO possui nenhum HookRequest.
model HookRequest {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  type          HookRequestType
  status        HookRequestStatus
  reason        String?           // motivo (defeito/perda no PAID; texto da bonificação no BONUS)
  paymentId     String?           @db.ObjectId // vínculo ao Payment (apenas PAID)
  grantedById   String?           @db.ObjectId // admin que concedeu (apenas BONUS)
  requestedAt   DateTime?         // quando entrou na fila de entrega (status REQUESTED)
  deliveredAt   DateTime?         // quando o admin registrou a entrega
  deliveredById String?           @db.ObjectId // admin que entregou (auditoria)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([status, requestedAt])
}

// 15. Notification — fila de notificações por tipo (imutável — sem updatedAt)
model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  userId      String           @db.ObjectId
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  actionRoute String?
  createdAt   DateTime         @default(now())
}

// 16. Session — persistent device sessions
model Session {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  token      String   @unique
  deviceId   String
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// AdminNote — notas internas do admin sobre um cliente (suporte/CRM)
model AdminNote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  adminId   String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())
}

// 17. OtpCode — one-time codes for login and registration
model OtpCode {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  code      String
  channel   String
  expiresAt DateTime
  usedAt    DateTime?
  purpose   String?
  createdAt DateTime  @default(now())
}

// 18. SavedCard — cartões salvos do cliente (Stripe PaymentMethod; mpCardId legado)
model SavedCard {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  mpCardId  String?
  stripePaymentMethodId String?
  brand     String
  lastFour  String
  expiresAt String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

// MaterializedCycle — marca persistida de que o ciclo de corte de um (condomínio, slot, dia de
// entrega) já foi materializado. Substitui o Set em memória: permite o backfill recuperar cortes
// perdidos mesmo cruzando a meia-noite e sobreviver a restart do servidor. `deliveryDate` é a data
// BRT da entrega no formato YYYY-MM-DD (absoluta), não HH:MM.
model MaterializedCycle {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  condominiumId String   @db.ObjectId
  slotId        String
  deliveryDate  String
  createdAt     DateTime @default(now())

  @@unique([condominiumId, slotId, deliveryDate])
}

// 19. AnalyticsEvent — eventos de acesso e login para os Relatórios (imutável — sem updatedAt)
// Stream único que permite calcular a conversão acesso→login pelo mesmo `visitorId`.
// `visitorId` é o device_id anônimo gerado no cliente (sem PII).
model AnalyticsEvent {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  type      AnalyticsEventType
  visitorId String             // ID anônimo do dispositivo (device_id do cliente)
  userId    String?            @db.ObjectId // preenchido apenas em LOGIN
  role      String?            // CLIENT | COURIER | ADMIN (em LOGIN)
  path      String?            // rota/tela inicial no momento do evento
  referrer  String?
  platform  String?            // 'pwa' | 'browser'
  userAgent String?            // para breakdown de SO/dispositivo
  createdAt DateTime           @default(now())

  @@index([type, createdAt])
  @@index([visitorId, createdAt])
}
